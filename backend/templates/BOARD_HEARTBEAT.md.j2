python3 - <<'PY'
import json
order = [{% if is_qa or is_architect %}"review", "inbox"{% else %}"in_progress", "rework", "inbox", "review"{% endif %}]
tasks = json.load(open("/tmp/mc-my-tasks.json")).get("items", [])
for status in order:
